      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "expr": "sum(up{job=~\"circleguard-.*\"})",
          "legendFormat": "services up",
          "refId": "A"
        }
      ],
      "title": "Service Status",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 9, "x": 6, "y": 0 },
      "id": 2,
      "targets": [
        {
          "expr": "sum by (job) (rate(http_server_requests_seconds_count{job=~\"circleguard-.*\"}[5m]))",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "title": "Requests per Second",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 9, "x": 15, "y": 0 },
      "id": 3,
      "targets": [
        {
          "expr": "sum by (job) (rate(http_server_requests_seconds_sum{job=~\"circleguard-.*\"}[5m])) / sum by (job) (rate(http_server_requests_seconds_count{job=~\"circleguard-.*\"}[5m]))",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "title": "Average Request Latency",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 4,
      "targets": [
        {
          "expr": "sum by (job, status) (rate(http_server_requests_seconds_count{job=~\"circleguard-.*\",status=~\"5..\"}[5m]))",
          "legendFormat": "{{job}} {{status}}",
          "refId": "A"
        }
      ],
      "title": "HTTP 5xx Errors",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": { "unit": "bytes" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 5,
      "targets": [
        {
          "expr": "sum by (job, area) (jvm_memory_used_bytes{job=~\"circleguard-.*\"})",
          "legendFormat": "{{job}} {{area}}",
          "refId": "A"
        }
      ],
      "title": "JVM Memory Used",
      "type": "timeseries"
    }
