pipeline {
    agent any

    options {
        // Retencion: solo conservar los ultimos 5 builds y sus artifacts.
        // Sin esto, cada build acumula ~1.5 GB en el agente.
        buildDiscarder(logRotator(numToKeepStr: '5', artifactNumToKeepStr: '5'))
        timeout(time: 60, unit: 'MINUTES')
        disableConcurrentBuilds()
        timestamps()
    }

    environment {
        KUBE_NAMESPACE = 'circleguard-dev'
        SERVICES = 'circleguard-auth-service circleguard-identity-service circleguard-form-service circleguard-promotion-service circleguard-notification-service circleguard-gateway-service'
        BUILD_CHANNEL = 'dev'
        // Optional. Configure these in Jenkins → Manage → Credentials or in the job config.
        // SONAR_HOST_URL = 'http://sonarqube:9000'
        // SONAR_TOKEN = credentials('sonar-token')
        // NOTIFICATION_RECIPIENTS = 'devops@example.com'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                script {
                    lib = load 'jenkins/shared.groovy'
                    env.IMAGE_TAG = lib.computeVersion('dev')
                    echo "Computed image tag: ${env.IMAGE_TAG}"
                }
            }
        }

        stage('Build Gradle') {
            steps {
                script { lib.runGradle('bootJar') }
            }
        }

        stage('Unit Tests') {
            steps {
                script { lib.runGradle('test') }
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: 'services/*/build/test-results/test/*.xml'
                    // Publish JaCoCo coverage reports generated by jacocoTestReport task
                    publishHTML(target: [
                        allowMissing          : true,
                        alwaysLinkToLastBuild : false,
                        keepAll               : false,
                        reportDir             : 'services/circleguard-auth-service/build/reports/jacoco/test/html',
                        reportFiles           : 'index.html',
                        reportName            : 'Coverage Report (auth-service)',
                        reportTitles          : 'JaCoCo Coverage'
                    ])
                    archiveArtifacts artifacts: 'services/*/build/reports/jacoco/**/*.xml', allowEmptyArchive: true
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                script { lib.runSonarAnalysis(env.IMAGE_TAG) }
            }
        }

        stage('Build Docker Images') {
            steps {
                script { lib.buildDockerImages(env.IMAGE_TAG) }
            }
        }

        stage('Trivy Container Scan') {
            steps {
                // Advisory only in dev (does not fail the build)
                script { lib.runTrivyScan(env.IMAGE_TAG, false) }
            }
        }

        stage('Deploy Kubernetes Dev') {
            steps {
                script {
                    if (lib.hasKubectl()) {
                        lib.kubectlApply()
                        lib.rolloutAll()
                    } else {
                        echo 'kubectl no esta instalado en el agente Jenkins; se omite despliegue Kubernetes en esta ejecucion local'
                    }
                }
            }
        }

        stage('Smoke Tests') {
            steps {
                script {
                    if (lib.hasKubectl()) {
                        lib.runCommand("kubectl get pods -n ${env.KUBE_NAMESPACE}")
                        lib.runCommand("kubectl get svc -n ${env.KUBE_NAMESPACE}")
                        lib.smokeTest('circleguard-auth-service', '8180')
                    } else {
                        echo 'kubectl no esta instalado en el agente Jenkins; se omite smoke test Kubernetes en esta ejecucion local'
                    }
                }
            }
        }
    }

    post {
        failure {
            script {
                try {
                    def libRef = load 'jenkins/shared.groovy'
                    libRef.notifyOnFailure()
                } catch (Exception e) {
                    echo "No se pudo enviar notificacion de fallo: ${e.message}"
                }
            }
        }
        always {
            archiveArtifacts artifacts: 'services/*/build/reports/**/*', allowEmptyArchive: true, fingerprint: false
            script {
                try {
                    def libRef = load 'jenkins/shared.groovy'
                    if (env.IMAGE_TAG) { libRef.cleanupDockerImages(env.IMAGE_TAG) }
                    libRef.cleanupWorkspace()
                } catch (Exception e) {
                    echo "Cleanup parcial: ${e.message}"
                }
            }
        }
    }
}
